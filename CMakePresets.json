{
    "version": 3,
    "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (Release)",
            "description": "Single-config Release build into build/",
            "binaryDir": "${sourceDir}/build",
            "generator": "Unix Makefiles",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "debug",
            "inherits": "default",
            "displayName": "Debug",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "RCAT_WARNINGS_AS_ERRORS": "ON"
            }
        },
        {
            "name": "asan",
            "inherits": "debug",
            "displayName": "AddressSanitizer + UBSan",
            "binaryDir": "${sourceDir}/build-asan",
            "cacheVariables": { "RCAT_ENABLE_ASAN": "ON" }
        },
        {
            "name": "tsan",
            "inherits": "debug",
            "displayName": "ThreadSanitizer",
            "binaryDir": "${sourceDir}/build-tsan",
            "cacheVariables": { "RCAT_ENABLE_TSAN": "ON" }
        },
        {
            "name": "coverage",
            "inherits": "debug",
            "displayName": "Coverage (gcov)",
            "binaryDir": "${sourceDir}/build-coverage",
            "cacheVariables": { "RCAT_ENABLE_COVERAGE": "ON" }
        },
        {
            "name": "ninja",
            "inherits": "default",
            "displayName": "Ninja release",
            "binaryDir": "${sourceDir}/build-ninja",
            "generator": "Ninja"
        }
    ],
    "buildPresets": [
        { "name": "default",  "configurePreset": "default" },
        { "name": "debug",    "configurePreset": "debug" },
        { "name": "asan",     "configurePreset": "asan" },
        { "name": "tsan",     "configurePreset": "tsan" },
        { "name": "coverage", "configurePreset": "coverage" },
        { "name": "ninja",    "configurePreset": "ninja" }
    ],
    "testPresets": [
        { "name": "default",  "configurePreset": "default",
          "output": { "outputOnFailure": true } },
        { "name": "debug",    "configurePreset": "debug",
          "output": { "outputOnFailure": true } },
        { "name": "asan",     "configurePreset": "asan",
          "output": { "outputOnFailure": true } },
        { "name": "tsan",     "configurePreset": "tsan",
          "output": { "outputOnFailure": true } },
        { "name": "coverage", "configurePreset": "coverage",
          "output": { "outputOnFailure": true } }
    ]
}
