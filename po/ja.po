#: src/rcat.cpp:131
msgid "Render Markdown — and many other source/config files — in the terminal."
msgstr ""
"ターミナル上で Markdown と多くのソースコード／設定ファイルを描画します。"

#: src/rcat.cpp:133
msgid ""
"Reads from stdin if no FILE is given (or FILE is '-').\n"
"Image paths are resolved relative to each FILE's directory.\n"
"Non-Markdown files (detected by extension or --lang) are rendered\n"
"with syntax highlighting instead of through the Markdown parser."
msgstr ""
"FILE が指定されない場合（または FILE が '-' の場合）標準入力から読み込みま"
"す。\n"
"画像のパスは各 FILE のディレクトリを基準に解決されます。\n"
"Markdown 以外のファイル（拡張子または --lang で判定）は\n"
"Markdown パーサーを通さずシンタックスハイライトで描画されます。"

#: src/rcat.cpp:139 src/rless.cpp:178
msgid "show version and exit"
msgstr "バージョンを表示して終了します"

#: src/rcat.cpp:144 src/rless.cpp:183
msgid "wrap to N columns (default: terminal width)"
msgstr "N 桁で折り返します（既定値: 端末の幅）"

#: src/rcat.cpp:149 src/rless.cpp:188
msgid "no styling at all (just wrapped text)"
msgstr "装飾を一切行わず、折り返したテキストのみ出力します"

#: src/rcat.cpp:154 src/rless.cpp:193
msgid "disable color (keep other styling/Unicode)"
msgstr "色を無効化します（他の装飾と Unicode は維持）"

#: src/rcat.cpp:159
msgid "emit colors even on non-TTY (e.g. piping to less -R)"
msgstr "非 TTY 出力でも色を出力します（例: less -R へのパイプ）"

#: src/rcat.cpp:164 src/rless.cpp:203
msgid "disable OSC 8 hyperlinks even if supported"
msgstr "対応端末でも OSC 8 ハイパーリンクを無効化します"

#: src/rcat.cpp:169 src/rless.cpp:208
msgid "don't render inline images"
msgstr "インライン画像を描画しません"

#: src/rcat.cpp:174 src/rless.cpp:213
msgid "download and render remote http(s) image URLs (off by default)"
msgstr "リモートの http(s) 画像をダウンロードして描画します（既定では無効）"

#: src/rcat.cpp:179 src/rless.cpp:218
msgid "seconds to wait per remote image fetch (default 10)"
msgstr "リモート画像 1 件あたりの待機秒数（既定値: 10）"

#: src/rcat.cpp:184 src/rless.cpp:223
msgid "cap image height to N rows (default 20)"
msgstr "画像の高さを N 行に制限します（既定値: 20）"

#: src/rcat.cpp:189 src/rless.cpp:228
msgid "force ASCII-only output (no box-drawing/bullets)"
msgstr "ASCII のみの出力を強制します（罫線や記号は使用しません）"

#: src/rcat.cpp:194 src/rless.cpp:233
msgid "force color mode: auto|none|16|256|truecolor"
msgstr "色モードを強制します: auto|none|16|256|truecolor"

#: src/rcat.cpp:199
msgid ""
"force source language (e.g. python, json, cpp); use 'md' for Markdown, "
"'list' to print every language"
msgstr ""

#: src/rcat.cpp:205 src/rless.cpp:249
msgid ""
"file(s); use '-' for stdin. Markdown by default, or any source/config file"
msgstr ""

#: src/rcat.cpp:213
msgid "Try 'rcat --help' for more information."
msgstr "詳細は 'rcat --help' を参照してください。"

#: src/rcat.cpp:227 src/rless.cpp:271
msgid "--columns must be >= 10"
msgstr "--columns は 10 以上である必要があります"

#: src/rcat.cpp:234 src/rless.cpp:278
msgid "--image-height must be >= 1"
msgstr "--image-height は 1 以上である必要があります"

#: src/rcat.cpp:247 src/rless.cpp:291
msgid "--web-timeout must be >= 1"
msgstr "--web-timeout は 1 以上である必要があります"

#: src/rcat.cpp:259 src/rless.cpp:303
msgid "invalid --color value"
msgstr "--color の値が不正です"

#: src/rcat.cpp:300
msgid "parse error"
msgstr "構文解析エラー"

#: src/renderer.cpp:232 src/renderer.cpp:245
msgid "image: "
msgstr "画像: "

#: src/rless.cpp:169
#, fuzzy
msgid ""
"Page through Markdown — and many other source/config files — in the terminal."
msgstr ""
"ターミナル上で Markdown と多くのソースコード／設定ファイルを描画します。"

#: src/rless.cpp:172
msgid ""
"Reads from stdin if no FILE is given (or FILE is '-').\n"
"When stdout is not a terminal, rless behaves like rcat and writes\n"
"the rendered output without paging.\n"
"Inside the pager, press 'h' for keybindings or 'q' to quit."
msgstr ""

#: src/rless.cpp:198
#, fuzzy
msgid "emit colors even on non-TTY (useful with --no-pager)"
msgstr "非 TTY 出力でも色を出力します（例: less -R へのパイプ）"

#: src/rless.cpp:238
msgid "force source language (e.g. python, json, cpp); use 'md' for Markdown"
msgstr ""

#: src/rless.cpp:244
msgid "never page: write the rendered output and exit (like rcat)"
msgstr ""

#: src/rless.cpp:257
#, fuzzy
msgid "Try 'rless --help' for more information."
msgstr "詳細は 'rcat --help' を参照してください。"

